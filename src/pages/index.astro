---
import Layout from '@/layouts/Layout.astro';
import SplashScreen from '@/components/SplashScreen.astro';
import Navbar from '@/components/partials/Navbar';
import Footer from '@/components/partials/Footer';
import Home from '@/components/sections/Home';
import Products from '@/components/sections/Products';
import Contact from '@/components/sections/Contact';
import FAQ from '@/components/sections/FAQ';
import { faqs } from '@/components/sections/FAQ';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};
---

<Layout
  title="Vespa DPM Cibubur – Dealer Resmi Vespa Matic Premium"
  description="Dealer resmi Vespa Matic di Cibubur. Sprint, Primavera, LX, dan Sprint S — cek koleksi lengkap dan hubungi kami via WhatsApp."
  image="/hero-image.jpeg"
  structuredData={faqSchema}
>
  <SplashScreen />

  <div id="landing-page" class="opacity-0 transition-opacity duration-700 ease-out">
    <Navbar client:load />
    <Home client:load />
    <div id="below-fold">
      <Products client:visible={{ rootMargin: '300px' }} />
      <Contact client:visible={{ rootMargin: '300px' }} />
      <FAQ client:visible={{ rootMargin: '300px' }} />
      <Footer />
    </div>
  </div>

  <script is:inline>
    (function () {
      var el = document.getElementById('landing-page');
      if (!el) return;

      function reveal() {
        el.style.opacity = '1';
      }

      window.addEventListener('vespa-splash-complete', reveal, { once: true });
      // fallback -> jaga-jaga kalau event splash tidak pernah terpicu.
      setTimeout(reveal, 6000);
    })();
  </script>
</Layout>