---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/partials/Navbar';
import Footer from '@/components/partials/Footer';
import ProductDetail from '@/components/sections/ProductDetail';
import { productsData, type Product } from '@/data/products';

export async function getStaticPaths() {
  return productsData.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;

// Rich snippet Product (harga, ketersediaan, brand) untuk hasil pencarian Google.
const priceValue = product.price.replace(/[^0-9]/g, '');
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  image: new URL(product.thumbnail, Astro.site).toString(),
  brand: { '@type': 'Brand', name: 'Vespa' },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'IDR',
    price: priceValue,
    availability: 'https://schema.org/InStock',
    url: new URL(`/products/${product.slug}`, Astro.site).toString(),
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Beranda', item: Astro.site?.toString() },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: new URL('/#products', Astro.site).toString() },
    {
      '@type': 'ListItem',
      position: 3,
      name: product.name,
      item: new URL(`/products/${product.slug}`, Astro.site).toString(),
    },
  ],
};
---

<Layout
  title={`${product.name} – Vespa DPM Cibubur`}
  description={product.description}
  image={product.thumbnail}
  structuredData={[productSchema, breadcrumbSchema]}
>
  <Navbar client:load />
  <ProductDetail product={product} client:load />
  <Footer />
</Layout>