---
// Banner persetujuan cookie untuk Google Consent Mode v2.
// Pure Astro + vanilla JS (tanpa React) supaya tetap ringan di critical path,
// konsisten dengan pola SplashScreen yang juga pure Astro.
const STORAGE_KEY = 'vespa-cookie-consent';
---

<div
  id="cookie-consent-banner"
  class="fixed inset-x-0 bottom-0 z-[10001] hidden translate-y-full border-t border-border bg-background/95 p-4 shadow-lg backdrop-blur-sm transition-transform duration-300 ease-out sm:p-6"
  role="dialog"
  aria-live="polite"
  aria-label="Persetujuan cookie"
>
  <div class="mx-auto flex max-w-4xl flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm text-foreground/80">
      Kami menggunakan cookie untuk analitik kunjungan situs (Google Analytics). Data hanya dikumpulkan
      setelah kamu klik "Terima".
    </p>
    <div class="flex w-full shrink-0 gap-2 sm:w-auto">
      <button
        id="cookie-consent-reject"
        type="button"
        class="flex-1 rounded-md border border-border px-4 py-2 text-sm font-medium text-foreground/70 transition-colors hover:bg-muted sm:flex-none"
      >
        Tolak
      </button>
      <button
        id="cookie-consent-accept"
        type="button"
        class="flex-1 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:opacity-90 sm:flex-none"
      >
        Terima
      </button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ STORAGE_KEY }}>
  (function () {
    var banner = document.getElementById('cookie-consent-banner');
    if (!banner) return;

    function updateConsent(granted) {
      if (typeof window.gtag !== 'function') return;
      window.gtag('consent', 'update', {
        ad_storage: granted ? 'granted' : 'denied',
        ad_user_data: granted ? 'granted' : 'denied',
        ad_personalization: granted ? 'granted' : 'denied',
        analytics_storage: granted ? 'granted' : 'denied',
      });
    }

    function hideBanner() {
      banner.classList.add('translate-y-full');
      setTimeout(function () {
        banner.classList.add('hidden');
      }, 300);
    }

    function showBanner() {
      banner.classList.remove('hidden');
      // requestAnimationFrame supaya transisi translate-y jalan (bukan langsung snap).
      requestAnimationFrame(function () {
        banner.classList.remove('translate-y-full');
      });
    }

    var stored = null;
    try {
      stored = localStorage.getItem(STORAGE_KEY);
    } catch (e) {}

    // Keputusan sudah pernah dibuat -> jangan tampilkan banner lagi.
    // (consent 'granted' sudah di-restore lebih awal di Layout, sebelum GA library load.)
    if (stored === 'granted' || stored === 'denied') {
      return;
    }

    showBanner();

    document.getElementById('cookie-consent-accept')?.addEventListener('click', function () {
      try {
        localStorage.setItem(STORAGE_KEY, 'granted');
      } catch (e) {}
      updateConsent(true);
      hideBanner();
    });

    document.getElementById('cookie-consent-reject')?.addEventListener('click', function () {
      try {
        localStorage.setItem(STORAGE_KEY, 'denied');
      } catch (e) {}
      updateConsent(false);
      hideBanner();
    });
  })();
</script>